<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Craftcms Test | Knecht</title>
  <link rel="stylesheet" href="https://knecht.works/styleguide/kit.css">
  <script src="https://knecht.works/styleguide/kit.js" defer></script>
  <link rel="icon" type="image/png" href="https://knecht.works/styleguide/favicon/favicon-96x96.png" sizes="96x96" />
  <link rel="icon" type="image/svg+xml" href="https://knecht.works/styleguide/favicon/favicon.svg" />
  <link rel="shortcut icon" href="https://knecht.works/styleguide/favicon/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="https://knecht.works/styleguide/favicon/apple-touch-icon.png" />
  <meta name="apple-mobile-web-app-title" content="Knecht" />
  <link rel="manifest" href="https://knecht.works/styleguide/favicon/site.webmanifest" />
  <meta name="robots" content="noindex,follow" />
  {{ craft.vite.script('src/js/app.js', false) }}
</head>
<body class="kit-body kit-light">
  <main class="kit-container">
    {% block main %}
      {% block navigation %}
        {%- set localizedEntries = entry.localized.eagerly().all()|index('site.id') -%}

        <div class="flex items-center justify-between">
          <a href="{{ currentSite.baseUrl }}" class="flex items-center text-black!">
            <img class="h-10" src="https://knecht.works/styleguide/assets/knecht-head.svg" alt="Knecht">
            <span class="font-bold text-xl text-current">Knecht</span>
          </a>
          <nav class="flex gap-6 items-center font-bold">
            {% for navEntry in craft.entries.all() %}
              <a href="{{ navEntry.getUrl() }}" class="text-black!">
                {{ navEntry.title }}
              </a>
            {% endfor %}
            <a href="https://knecht.works" target="_blank" class="text-black!">
              Knecht
            </a>
            <label for="language-switcher" class="sr-only">{{ 'Language'|t }}</label>
            <select id="language-switcher" class="cursor-pointer" aria-label="{{ 'Language'|t }}" onchange="window.location.href = this.value">
              {%- for site in craft.app.sites.allSites -%}
                {%- if site.enabled -%}
                  {%- set localizedEntry = localizedEntries[site.id] ?? null -%}
                  {%- set url = localizedEntry ? localizedEntry.url : site.baseUrl -%}
                  <option value="{{ url }}" {% if site.id == currentSite.id %}selected{% endif %}>{{ site.name }}</option>
                {%- endif -%}
              {%- endfor -%}
            </select>
          </nav>
        </div>
      {% endblock navigation %}

      {% llmify %}
      {% block hero %}
        <div class="mt-20">
          <div class="text-center">
            <span class="exclude-llmify kit-badge kit-mb-4">craftcms-test-e2e</span>

            <h1>{{ entry.headline ?? entry.title }}</h1>

            <p class="kit-muted mt-8">
              {{ entry.introText }}
            </p>
          </div>
          {% if entry.asset.eagerly().one() %}
            <div class="mt-8">
              <img class="rounded-lg overflow-hidden" src="{{ entry.asset.eagerly().one().getUrl() }}">
            </div>
          {% endif %}
        </div>
      {% endblock hero %}

      {% block content %}
        <div class="mt-20">
          {{ entry.content|raw }}
        </div>
      {% endblock content %}

      {% endllmify %}
      {% block footer %}
      {% endblock footer %}
    {% endblock main %}
  </main>
</body>
</html>
